<configs>
	<!-- ============================================================
	     ZOMBIE DENSITY OVERHAUL
	     10-20x outdoor zombie density across all biomes.
	     Pine Forest stays easiest. Wasteland is the hardest.
	     
	     Key levers:
	       maxcount = max alive per 80x80m biome chunk
	       respawndelay = game days between respawns (lower = faster)
	     ============================================================ -->


	<!-- ============================
	     PINE FOREST (Easy — RPG safe zone)
	     Day: 1→5, Night: 1→7
	     ============================  -->

	<!-- Day wilderness: 1→5, faster respawn -->
	<set xpath="/spawning/biome[@name='pine_forest']/spawn[@id='dz01']/@maxcount">5</set>
	<set xpath="/spawning/biome[@name='pine_forest']/spawn[@id='dz01']/@respawndelay">0.5</set>

	<!-- Night wilderness: 1→7 -->
	<set xpath="/spawning/biome[@name='pine_forest']/spawn[@id='nz01']/@maxcount">7</set>
	<set xpath="/spawning/biome[@name='pine_forest']/spawn[@id='nz01']/@respawndelay">0.3</set>

	<!-- Day commercial/industrial: 2→10 -->
	<set xpath="/spawning/biome[@name='pine_forest']/spawn[@id='dz02']/@maxcount">10</set>
	<set xpath="/spawning/biome[@name='pine_forest']/spawn[@id='dz02']/@respawndelay">0.05</set>

	<!-- Night commercial/industrial: 3→12 -->
