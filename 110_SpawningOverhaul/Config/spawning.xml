<configs>
	<!-- ============================================================
	     ZOMBIE DENSITY OVERHAUL — "Towns are Terrifying, Woods are Safe"
	     
	     Wilderness: Sparse. Low maxcount, moderate respawn.
	     Commercial/Industrial: Dense. Outskirts-of-town danger.
	     Downtown: Packed. Left 4 Dead horde scene.
	     
	     Key levers:
	       maxcount = max alive per 80x80m biome chunk
	       respawndelay = game days between respawns (lower = faster)
	       
	     NOTE: respawndelay=0.5 ≈ 25 min real time. 
	           respawndelay=0.1 ≈ 5 min real time.
	           respawndelay=0.01 ≈ 30 sec real time.
	     ============================================================ -->


	<!-- ============================
	     PINE FOREST (Safest)
	     ============================ -->

	<!-- Day wilderness: sparse, 1 per chunk, respawns every ~12 min -->
	<set xpath="/spawning/biome[@name='pine_forest']/spawn[@id='dz01']/@maxcount">1</set>
	<set xpath="/spawning/biome[@name='pine_forest']/spawn[@id='dz01']/@respawndelay">0.25</set>

	<!-- Night wilderness: slightly more -->
	<set xpath="/spawning/biome[@name='pine_forest']/spawn[@id='nz01']/@maxcount">2</set>
	<set xpath="/spawning/biome[@name='pine_forest']/spawn[@id='nz01']/@respawndelay">0.2</set>

	<!-- Day commercial/industrial -->
	<set xpath="/spawning/biome[@name='pine_forest']/spawn[@id='dz02']/@maxcount">8</set>
	<set xpath="/spawning/biome[@name='pine_forest']/spawn[@id='dz02']/@respawndelay">0.05</set>

	<!-- Night commercial/industrial -->
	<set xpath="/spawning/biome[@name='pine_forest']/spawn[@id='nz02']/@maxcount">10</set>
	<set xpath="/spawning/biome[@name='pine_forest']/spawn[@id='nz02']/@respawndelay">0.03</set>

	<!-- Day downtown -->
