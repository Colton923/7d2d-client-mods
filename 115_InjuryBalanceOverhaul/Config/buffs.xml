<configs>

<!-- ============================================================ -->
<!-- 115_InjuryBalanceOverhaul                                     -->
<!-- Fixes consumable buff display timers + reduces injury times.   -->
<!-- ============================================================ -->

<!-- ============================================================ -->
<!-- GLOBAL FIX: Force $MetabolismDuration >= 1                    -->
<!-- ROOT CAUSE: 060_ProgressionOverhaul removed perkSlowMetabolism -->
<!-- which was the ONLY place $MetabolismDuration gets set.         -->
<!-- Every consumable buff divides display by this cvar.            -->
<!-- When it's 0 (unset): counter / 0 = 2000+ hours displayed.     -->
<!--                                                                -->
<!-- Also force $critHitNaturalHealingRate >= 1 for injury buffs.   -->
<!--                                                                -->
<!-- We inject into buffStatusCheck02 which ticks constantly on     -->
<!-- all players — single fix for every buff in the game.           -->
<!-- ============================================================ -->

<append xpath="/buffs/buff[@name='buffStatusCheck02']/effect_group[1]">
    <!-- If $MetabolismDuration is 0 or unset, default to 1 -->
    <triggered_effect trigger="onSelfBuffUpdate" action="ModifyCVar" cvar="$MetabolismDuration" operation="set" value="1">
        <requirement name="CVarCompare" cvar="$MetabolismDuration" operation="LTE" value="0"/>
    </triggered_effect>
    <!-- If $critHitNaturalHealingRate is 0 or unset, default to 1 -->
    <triggered_effect trigger="onSelfBuffUpdate" action="ModifyCVar" cvar="$critHitNaturalHealingRate" operation="set" value="1">
        <requirement name="CVarCompare" cvar="$critHitNaturalHealingRate" operation="LTE" value="0"/>
    </triggered_effect>
</append>

